# ============================================
# {{ project_name | default("Project") }} - Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# === App ===
APP_NAME={{ project_name | default("MyApp") }}
APP_ENV=development
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=change-me-in-production

{% if include_db %}
# === Database ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME={{ project_name | default("app") | lower | replace(" ", "-") }}
DB_USER=postgres
DB_PASSWORD=postgres
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
{% endif %}

{% if include_auth %}
# === Authentication ===
JWT_SECRET=change-me
JWT_EXPIRATION=3600
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
{% endif %}

{% if variables %}
# === Custom Variables ===
{% for line in variables.strip().splitlines() %}
{{ line }}
{% endfor %}
{% endif %}
